{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfpractice12026"
		},
		"LS_AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_AzureBlobStorage1'"
		},
		"LS_AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_AzureDataLakeStorage1'"
		},
		"LS_Multiple_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Multiple'"
		},
		"LS_SqlServer_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SqlServer'"
		},
		"LS_AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stadlsgen22026.dfs.core.windows.net/"
		},
		"LS_SqlServer_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-RPM7C61\\SQLEXPRESS"
		},
		"LS_SqlServer_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ADFTraining"
		},
		"LS_SqlServer_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adfuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfpractice12026_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AzureBlobStorage1_connectionString": {
						"value": "[parameters('LS_AzureBlobStorage1_connectionString')]"
					},
					"LS_AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('LS_AzureDataLakeStorage1_accountKey')]"
					},
					"LS_Multiple_connectionString": {
						"value": "[parameters('LS_Multiple_connectionString')]"
					},
					"LS_SqlServer_password": {
						"value": "[parameters('LS_SqlServer_password')]"
					},
					"LS_AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('LS_AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"LS_SqlServer_properties_typeProperties_server": {
						"value": "[parameters('LS_SqlServer_properties_typeProperties_server')]"
					},
					"LS_SqlServer_properties_typeProperties_database": {
						"value": "[parameters('LS_SqlServer_properties_typeProperties_database')]"
					},
					"LS_SqlServer_properties_typeProperties_userName": {
						"value": "[parameters('LS_SqlServer_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}